Encoding: UTF-8
Roxygen: list(markdown = TRUE)
Depends:
    R (>= 4.1.0)
Imports:
    bslib (>= 0.9.0),
    brand.yml,
    cli,
    htmltools,
    yaml,
Suggests:
    ggplot2,
    testthat (>= 3.0.0),
    thematic
Config/testthat/edition: 3
Config/roxygen2/version: 8.0.0
URL: https://github.com/shelbylevel/slbrand
BugReports: https://github.com/shelbylevel/slbrand/issues
